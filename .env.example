# LLM API Configuration
LLM_PROVIDER=openai  # or "anthropic"
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Nextflow Tower Configuration
TOWER_API_ENDPOINT=https://api.tower.nf
TOWER_ACCESS_TOKEN=
TOWER_WORKSPACE=

# EASI-FISH Knowledge Base
MULTIFISH_KNOWLEDGE_DIR=/path/to/multifish-mcp/src/multifish_mcp/knowledge
MULTIFISH_KNOWLEDGE_REPO=  # e.g. git@github.com:your-org/multifish-knowledge.git
MULTIFISH_KNOWLEDGE_BRANCH=main

# Data Sources
CELLXGENE_CENSUS_VERSION=stable

# Application Settings
MAX_UPLOAD_SIZE_MB=500
LOG_LEVEL=INFO

# App Password (SHA-256 hash, leave empty to disable)
# Generate with: python -c "import hashlib; print(hashlib.sha256(b'your_password').hexdigest())"
APP_PASSWORD_HASH=
